<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SMOKE SUITE — runs the critical login path.
  Triggered on every commit / PR check.
  Expected duration: < 3 minutes.
-->
<suite name="OrangeHRM - Smoke Suite"
       verbose="2"
       parallel="methods"
       thread-count="2">

    <listeners>
        <listener class-name="com.orangehrm.listeners.TestListener"/>
    </listeners>

    <test name="Login Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="com.orangehrm.tests.LoginTest"/>
        </classes>
    </test>

</suite>
