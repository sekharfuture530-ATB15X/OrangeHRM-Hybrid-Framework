<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  FULL SUITE — runs ALL tests: POM, Data-Driven, and Keyword-Driven.
  Use for complete coverage validation before a release.
-->
<suite name="OrangeHRM - Full Hybrid Suite"
       verbose="2"
       parallel="methods"
       thread-count="3">

    <listeners>
        <listener class-name="com.orangehrm.listeners.AnnotationTransformer"/>
        <listener class-name="com.orangehrm.listeners.TestListener"/>
    </listeners>

    <!-- ── POM + Data-Driven Tests ───────────────────────── -->
    <test name="Login - POM and Data-Driven">
        <classes>
            <class name="com.orangehrm.tests.LoginTest"/>
        </classes>
    </test>

    <!-- ── Keyword-Driven Tests ──────────────────────────── -->
    <test name="Login - Keyword-Driven">
        <classes>
            <class name="com.orangehrm.tests.KeywordDrivenTest"/>
        </classes>
    </test>

</suite>
